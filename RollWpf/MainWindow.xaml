                            <Expander Header="卡牌 / 药水结果筛选（已并入最终结果导向，暂不单独筛）" IsExpanded="False" Visibility="Collapsed" Margin="0,0,0,12">
                                <Border Style="{StaticResource Card}" Margin="0">
                                    <StackPanel>
                                        <TextBlock Text="卡牌机会用于万花筒、新叶、卷轴类、变化/选牌等可能产生卡牌结果的路线。当前先提供常用 own/colorless/other 三类开关。" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,0,0,8" />
