                                        </UniformGrid>
                                    </StackPanel>
                                </Border>
                            </Expander>

                            <Expander Header="先古之民筛选" IsExpanded="False" Margin="0,0,0,12">
                                <Border Style="{StaticResource Card}" Margin="0">
                                    <StackPanel>
                                        <CheckBox x:Name="AncientSearchEnabledCheckBox" Content="启用先古筛选" Margin="4,0,4,8" />
                                        <TextBlock Text="可以筛“是谁 / 不是谁”，也可以筛“需要某个定向选项 / 不想要某个定向选项”。下拉框已排除 Neow 选项，并优先显示中文名；状态预设用于告诉工具当前游戏状态，否则条件选项无法准确判断。" TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}" Margin="4,0,4,8" />
                                        <UniformGrid Columns="3" Margin="0,0,0,8">
                                            <StackPanel Margin="0,0,8,0">
                                                <TextBlock Text="先古之民" />
                                                <ComboBox x:Name="AncientBuilderComboBox" IsEditable="True" IsTextSearchEnabled="True" DisplayMemberPath="DisplayText" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,0,8,0">
