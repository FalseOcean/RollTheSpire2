                                <TextBlock DockPanel.Dock="Top" Text="粗筛候选池" FontWeight="SemiBold" Margin="4,0,4,8" />
                                <DataGrid x:Name="CandidatePoolsDataGrid" AutoGenerateColumns="False" IsReadOnly="True" SelectionChanged="CandidatePoolsDataGrid_SelectionChanged" CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="Horizontal">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="150" />
                                        <DataGridTextColumn Header="角色" Binding="{Binding Character}" Width="118" />
                                        <DataGridTextColumn Header="A" Binding="{Binding AscensionText}" Width="42" />
                                        <DataGridTextColumn Header="Seeds" Binding="{Binding SeedCount}" Width="62" />
                                        <DataGridTextColumn Header="更新时间" Binding="{Binding UpdatedAtText}" Width="132" />
                                        <DataGridTextColumn Header="摘要" Binding="{Binding Summary}" Width="*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </Border>
                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
