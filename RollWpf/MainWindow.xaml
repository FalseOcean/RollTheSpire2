<Window x:Class="RollWpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RollTheSpire2 v2.1.0" Height="860" Width="1420" MinHeight="720" MinWidth="1120"
        Background="{StaticResource AppBackground}" FontFamily="Microsoft YaHei UI">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Margin="20,22,20,12">
                    <TextBlock Text="RollTheSpire2" Foreground="White" FontSize="26" FontWeight="Bold" />
                    <TextBlock Text="Slay the Spire 2" Foreground="#9CA3AF" FontSize="13" Margin="0,4,0,18" />
                    <Button x:Name="NavConfigButton" Content="配置" Click="NavConfig_Click" />
                    <Button x:Name="NavAnalyzeButton" Content="单种分析" Click="NavAnalyze_Click" />
                    <Button x:Name="NavSearchButton" Content="批量筛种" Click="NavSearch_Click" />
                    <Button x:Name="NavSearchResultsButton" Content="筛种结果" Click="NavSearchResults_Click" />
                    <Button x:Name="NavHistoryButton" Content="种子收藏" Click="NavHistory_Click" />
                    <Button x:Name="NavCandidateButton" Content="粗筛库" Click="NavCandidate_Click" />
                    <Button x:Name="NavEventsButton" Content="事件百科" Click="NavEvents_Click" />
                    <Button x:Name="NavLogButton" Content="运行日志" Click="NavLog_Click" />
                    <Button x:Name="NavStatusButton" Content="数据状态" Click="NavStatus_Click" />
                </StackPanel>
                <StackPanel DockPanel.Dock="Bottom" Margin="18" >
                    <TextBlock Text="v2.1.0" Foreground="#D1D5DB" FontSize="12" />
                    <TextBlock x:Name="SidebarStatusText" Text="RollCore 已引用" Foreground="#9CA3AF" TextWrapping="Wrap" FontSize="12" Margin="0,4,0,0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,16">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock x:Name="PageTitleText" Text="单种分析" FontSize="26" FontWeight="Bold" Foreground="#111827" />
                    <TextBlock x:Name="PageSubtitleText" Text="RollTheSpire2 桌面版：单种分析 / 批量筛种 / 收藏库 / 粗筛库。" FontSize="13" Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0" />
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="打开配置" Click="OpenConfig_Click" />
                    <Button Content="打开项目目录" Click="OpenProject_Click" />
                </StackPanel>
            </DockPanel>

            <Grid Grid.Row="1">
                <ScrollViewer x:Name="ConfigPage" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                    <StackPanel>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="基础配置" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock Text="WPF 当前读取项目根目录 config.json，并在运行时临时覆盖常用项；不会直接改写你的原始配置。" Foreground="{StaticResource MutedTextBrush}" Margin="0,6,0,12" />
                                <UniformGrid Columns="2">
                                    <StackPanel>
                                        <TextBlock Text="项目根目录" />
                                        <TextBox x:Name="RootDirTextBox" IsReadOnly="True" />
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="配置文件" />
                                        <TextBox x:Name="ConfigPathTextBox" IsReadOnly="True" />
                                    </StackPanel>
                                </UniformGrid>
                                <StackPanel Margin="0,12,0,0">
                                    <TextBlock Text="游戏 RNG 版本" />
                                    <ComboBox x:Name="GameRngVersionComboBox" SelectedValuePath="Tag" ToolTip="v2 默认使用 STS2 v0.107.1+ 的 xoshiro256**。Legacy 仅用于旧游戏版本 / v1.x 结果复查。">
                                        <ComboBoxItem Content="STS2 v0.107.1+ / xoshiro256**（新版，推荐）" Tag="sts2_0_107_xoshiro" IsSelected="True" />
                                        <ComboBoxItem Content="Legacy / v1.x 旧 RNG" Tag="legacy" />
                                    </ComboBox>
                                    <TextBlock Text="注意：用户可见 seed 仍按源码默认 10 位处理；新版多人 RNG 使用玩家槽位 / Lobby 顺序，不再用 NetId 派生。" Foreground="{StaticResource MutedTextBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,6,0,0" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="玩家存档 / 解锁档案" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock Text="导入 progress.save 后会生成 profiles/unlock_profile.json。默认不勾选时使用全解锁模式；勾选后才按 progress.save 限制卡牌、遗物、药水、事件等解锁池。单人仍使用 net_id=1；progress.save 的 unique_id 只用于识别档案。" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,6,0,12" />
                                <DockPanel Margin="0,0,0,8">
                                    <WrapPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
                                        <Button Content="自动导入默认 progress.save" Click="AutoImportProgressSave_Click" Background="{StaticResource PrimaryBrush}" Foreground="White" Margin="8,0,0,0" />
                                        <Button Content="手动导入 progress.save" Click="ImportProgressSave_Click" Margin="8,0,0,0" />
                                    </WrapPanel>
                                    <CheckBox x:Name="UseProgressProfileCheckBox" Content="按 progress.save 限制解锁池" VerticalAlignment="Center" IsChecked="False" ToolTip="不勾选时使用默认全解锁模式；勾选后按导入的 progress.save / unlock_profile.json 过滤解锁池。" />
                                </DockPanel>
                                <TextBlock Text="默认会扫描 SlayTheSpire2\steam\&lt;SteamID&gt;\profileN\saves\progress.save 与 modded\profileN\saves\progress.save；如果不在这些位置，可手动导入。" Foreground="{StaticResource MutedTextBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,6" />
                                <TextBox x:Name="UnlockProfilePathTextBox" IsReadOnly="True" FontFamily="Consolas, Microsoft YaHei UI" Text="profiles/unlock_profile.json" />
                                <TextBlock x:Name="UnlockProfileStatusText" Text="当前：默认全解锁。" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,6,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="单人 / 多人运行模式" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock Text="多人配置保留在配置页；v0.107+ 新版 RNG 按 Lobby Players 最终列表顺序 / 玩家槽位派生 PlayerRng，NetId 只作为身份备注。筛种页会提示当前你是谁；筛种页改角色会同步到目标玩家。" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,6,0,12" />
                                <UniformGrid Columns="2" Margin="0,0,0,8">
                                    <StackPanel Margin="0,0,8,0">
                                        <TextBlock Text="运行模式" />
                                        <ComboBox x:Name="RunModeComboBox" SelectionChanged="RunModeComboBox_SelectionChanged">
                                            <ComboBoxItem Content="单人" Tag="singleplayer" IsSelected="True" />
                                            <ComboBoxItem Content="多人" Tag="multiplayer" />
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,8,0">
                                        <TextBlock Text="玩家数" />
                                        <ComboBox x:Name="MultiplayerPlayersCountComboBox" SelectionChanged="MultiplayerPlayersCountComboBox_SelectionChanged">
                                            <ComboBoxItem Content="2" Tag="2" IsSelected="True" />
                                            <ComboBoxItem Content="3" Tag="3" />
                                            <ComboBoxItem Content="4" Tag="4" />
                                            <ComboBoxItem Content="5" Tag="5" />
                                            <ComboBoxItem Content="6" Tag="6" />
                                            <ComboBoxItem Content="7" Tag="7" />
                                            <ComboBoxItem Content="8" Tag="8" />
                                        </ComboBox>
                                    </StackPanel>
                                </UniformGrid>

                                <DockPanel Margin="0,4,0,10">
                                    <WrapPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
                                        <Button Content="添加玩家" Width="92" Click="AddMultiplayerPlayer_Click" />
                                        <Button Content="清空列表" Width="92" Click="ClearMultiplayerPlayers_Click" Background="#FF6B6B" Foreground="White" />
                                    </WrapPanel>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="多人玩家表 / 加入顺序" FontWeight="SemiBold" />
                                        <TextBlock Text="  ·  行顺序会影响预测" Foreground="{StaticResource MutedTextBrush}" />
                                    </StackPanel>
                                </DockPanel>

                                <TextBlock Text="按 host 发出的 Lobby Players 最终列表顺序填写；行号就是 v0.107+ RNG 的 player slot index。NetId 可填 NetId / 身份备注，但新版 RNG 不用它派生。目标玩家会同步到单种/筛种页当前角色。" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,0,0,8" />

                                <ItemsControl x:Name="MultiplayerPlayersItemsControl" Margin="0,0,0,8" HorizontalAlignment="Stretch">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,8" HorizontalAlignment="Stretch">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="52" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="236" />
                                                    </Grid.ColumnDefinitions>

                                                    <Border Grid.Column="0" Width="36" Height="36" Background="#E0F2FE" BorderBrush="#BAE6FD" BorderThickness="1" CornerRadius="18" HorizontalAlignment="Center" VerticalAlignment="Top">
                                                        <TextBlock Text="{Binding Order}" FontSize="16" FontWeight="Bold" Foreground="#0369A1" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>

                                                    <StackPanel Grid.Column="1" Margin="4,0,12,0">
                                                        <DockPanel Margin="0,0,0,6">
                                                            <CheckBox DockPanel.Dock="Left" Content="参与" IsChecked="{Binding Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Checked="MultiplayerRosterFieldChanged" Unchecked="MultiplayerRosterFieldChanged" Foreground="#15803D" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                            <TextBlock Text="按加入顺序排列；右侧按钮可把该玩家设为当前单种/筛种目标。" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" FontSize="12" Margin="12,0,0,0" VerticalAlignment="Center" />
                                                        </DockPanel>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="1.05*" />
                                                                <ColumnDefinition Width="1.35*" />
                                                                <ColumnDefinition Width="1.05*" />
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                                                <TextBlock Text="玩家名 / 备注" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                                                                <TextBox Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextChanged="MultiplayerRosterFieldChanged" HorizontalContentAlignment="Left" />
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                                                <TextBlock Text="NetId / 身份备注" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                                                                <TextBox Text="{Binding NetId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextChanged="MultiplayerRosterFieldChanged" ToolTip="填写真实 NetId / 身份备注。" HorizontalContentAlignment="Left" FontFamily="Consolas, Microsoft YaHei UI" />
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="2">
                                                                <TextBlock Text="角色" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                                                                <ComboBox SelectedValue="{Binding Character, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Tag" SelectionChanged="MultiplayerPlayerCharacter_SelectionChanged">
                                                                    <ComboBoxItem Content="铁甲战士（Ironclad）" Tag="IRONCLAD" />
                                                                    <ComboBoxItem Content="静默猎手（Silent）" Tag="SILENT" />
                                                                    <ComboBoxItem Content="故障机器人（Defect）" Tag="DEFECT" />
                                                                    <ComboBoxItem Content="亡灵契约师（Necrobinder）" Tag="NECROBINDER" />
                                                                    <ComboBoxItem Content="储君（Regent）" Tag="REGENT" />
                                                                </ComboBox>
                                                            </StackPanel>
                                                        </Grid>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                        <UniformGrid Columns="2">
                                                            <Button Content="上移" Click="MoveMultiplayerPlayerUp_Click" />
                                                            <Button Content="下移" Click="MoveMultiplayerPlayerDown_Click" />
                                                        </UniformGrid>
                                                        <UniformGrid Columns="2" Margin="0,4,0,0">
                                                            <Button Content="单种分析" Click="AnalyzeAsMultiplayerPlayer_Click" ToolTip="设为目标玩家，切到单种分析，并同步该玩家角色。" />
                                                            <Button Content="批量筛种" Click="SearchAsMultiplayerPlayer_Click" ToolTip="设为目标玩家，切到批量筛种，并同步该玩家角色。" />
                                                        </UniformGrid>
                                                        <Button Content="删除" Click="DeleteMultiplayerPlayer_Click" Background="#F87171" Foreground="White" Margin="4,4,4,0" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBox x:Name="TargetNetIdTextBox" Text="1" Visibility="Collapsed" TextChanged="TargetNetIdTextBox_TextChanged" />
                                <TextBox x:Name="MultiplayerPlayersTextBox" Text="1:IRONCLAD, 2:SILENT" Visibility="Collapsed" TextChanged="MultiplayerPlayersTextBox_TextChanged" />
                                <TextBlock x:Name="MultiplayerStatusText" Text="当前：单人模式，net_id=1。" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,6,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="高级设置" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock Text="这里放低频、偏整活或实验性的筛种能力；默认关闭，避免普通筛种流程被复杂选项污染。" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,6,0,12" />
                                <CheckBox x:Name="EnableAdvancedNewLeafCheckBox" Content="启用高级新叶：允许在筛种器里指定新叶变化的原始牌来源" IsChecked="False" ToolTip="关闭时，新叶始终按普通本职业基础牌变化逻辑筛选；打开后，在骨骰路线选择新叶时可额外指定铅制镇纸、万花筒、沉重石板等来源。" />
                                <TextBlock x:Name="AdvancedNewLeafConfigHintText" Text="当前：高级新叶关闭。筛种器里的新叶按普通模式处理。" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="22,6,0,8" />
                                <CheckBox x:Name="AnalyzeDetailedMapBossCheckBox" Content="单种分析地图/Boss 使用详细模式（显示怪物/精英队列）" IsChecked="False" ToolTip="默认关闭，只显示 Act 与 Boss；需要核对地图/怪物队列时再开启。" />
                                <CheckBox x:Name="AnalyzeShowFullEventQueueCheckBox" Content="单种分析事件队列显示完整队列（包含当前 Act 必跳过事件）" IsChecked="False" ToolTip="默认关闭：事件队列会隐藏当前 Act 必定不会自然出现的事件；开启后显示完整原始读取队列。" Margin="0,6,0,0" />
                                <CheckBox x:Name="MultiplayerUseProfileCheckBox" Content="多人模式也使用当前 progress.save 解锁档案近似" ToolTip="默认多人使用全解锁；勾选后写入 multiplayer_unlock_mode=profile，只用当前导入档案近似目标玩家解锁状态。" Margin="0,6,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="WPF 阶段说明" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock Text="当前主线是 WPF 批量筛种与 Tag Builder。单种分析已接入 Neow / 商店 / 先古 / 多人基础配置与结果卡片，但部分高级 Tag 的解释展示仍会逐步补齐。" TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}" Margin="0,6,0,0" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Grid x:Name="AnalyzePage">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Style="{StaticResource Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="1.05*" />
                                <ColumnDefinition Width="0.75*" />
                                <ColumnDefinition Width="0.9*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Seed" />
                                <TextBox x:Name="SeedTextBox" Text="ABC123" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="角色" />
                                <ComboBox x:Name="CharacterComboBox" SelectedValuePath="Tag">
                                    <ComboBoxItem Content="铁甲战士（Ironclad）" Tag="IRONCLAD" IsSelected="True" />
                                    <ComboBoxItem Content="静默猎手（Silent）" Tag="SILENT" />
                                    <ComboBoxItem Content="故障机器人（Defect）" Tag="DEFECT" />
                                    <ComboBoxItem Content="亡灵契约师（Necrobinder）" Tag="NECROBINDER" />
                                    <ComboBoxItem Content="储君（Regent）" Tag="REGENT" />
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="进阶等级（0-10）" />
                                <ComboBox x:Name="AnalyzeAscensionComboBox" SelectedIndex="0" ToolTip="STS2 当前进阶上限为 A10；A7 起自动使用高进阶稀有卡降低档。">
                                    <ComboBoxItem Content="A0" Tag="0" />
                                    <ComboBoxItem Content="A1" Tag="1" />
                                    <ComboBoxItem Content="A2" Tag="2" />
                                    <ComboBoxItem Content="A3" Tag="3" />
                                    <ComboBoxItem Content="A4" Tag="4" />
                                    <ComboBoxItem Content="A5" Tag="5" />
                                    <ComboBoxItem Content="A6" Tag="6" />
                                    <ComboBoxItem Content="A7" Tag="7" />
                                    <ComboBoxItem Content="A8" Tag="8" />
                                    <ComboBoxItem Content="A9" Tag="9" />
                                    <ComboBoxItem Content="A10" Tag="10" />
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="3">
                                <TextBlock Text="事件数量 / Act" />
                                <TextBox x:Name="EventLimitTextBox" Text="10" />
                            </StackPanel>
                            <StackPanel Grid.Column="4" VerticalAlignment="Bottom" Orientation="Horizontal">
                                <CheckBox x:Name="EnableEventCheckBox" Content="事件" IsChecked="True" VerticalAlignment="Center" Margin="8,0" />
                                <CheckBox x:Name="EnableShopCheckBox" Content="商店" VerticalAlignment="Center" Margin="8,0" />
                                <CheckBox x:Name="EnableAncientCheckBox" Content="先古" VerticalAlignment="Center" Margin="8,0" />
                                <CheckBox x:Name="AnalyzeMapBossCheckBox" Content="地图/Boss" ToolTip="默认只显示 Act 与 Boss；详细模式在配置页高级设置里开启。" VerticalAlignment="Center" Margin="8,0" />
                                <CheckBox x:Name="AnalyzeRelicSequenceCheckBox" Content="普通遗物序列" ToolTip="查看普通 / 罕见 / 稀有遗物队列；商店专属遗物请使用“商店”开关。" VerticalAlignment="Center" Margin="8,0" />
                                <Button x:Name="AnalyzeButton" Content="开始分析" Click="Analyze_Click" Background="{StaticResource PrimaryBrush}" Foreground="White" />
                                <Button Content="收藏当前" Click="SaveAnalyzeToHistory_Click" ToolTip="把当前单种分析结果保存到搜索历史 / 收藏库。" />
                            </StackPanel>
                            <DockPanel Grid.Row="1" Grid.ColumnSpan="5" Margin="0,10,0,0">
                                <TextBlock DockPanel.Dock="Left" Text="普通遗物序列数量" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" Margin="4,0,8,0" />
                                <ComboBox x:Name="AnalyzeRelicSequenceLimitComboBox" DockPanel.Dock="Left" Width="86" SelectedIndex="3" ToolTip="单种分析里 Common / Uncommon / Rare 普通遗物队列各显示多少个。默认 15。">
                                    <ComboBoxItem Content="5" Tag="5" />
                                    <ComboBoxItem Content="8" Tag="8" />
                                    <ComboBoxItem Content="10" Tag="10" />
                                    <ComboBoxItem Content="15" Tag="15" IsSelected="True" />
                                    <ComboBoxItem Content="20" Tag="20" />
                                    <ComboBoxItem Content="30" Tag="30" />
                                </ComboBox>
                                <TextBlock Text="只影响“普通遗物序列”，不影响商店专属遗物前 8 个。" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="8,0,0,0" />
                            </DockPanel>
                        </Grid>
                    </Border>
                    <StackPanel Grid.Row="1" Margin="0,0,0,8">
                        <Expander x:Name="AnalyzeAdvancedNewLeafExpander" Header="单种分析 · 高级新叶（仅骨骰路线，可选）" IsExpanded="False" Margin="0,0,0,8">
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="高级新叶只影响骨骰路线中的 NewLeaf；直接 Neow 三选一拿新叶仍按普通初始牌变化处理。配置页未启用高级新叶时，这里不会生效。" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,0,0,8" />
                                    <CheckBox x:Name="AnalyzeUseAdvancedNewLeafCheckBox" Content="单种分析使用高级新叶原始牌来源（仅骨骰路线）" IsChecked="False" ToolTip="勾选后，单种分析会把下面的来源写入 choices.NewLeafSelectedCard；RollCore 只在骨骰路线应用，直接 Neow 路线不应用。" />
                                    <DockPanel Margin="22,8,0,0">
                                        <TextBlock DockPanel.Dock="Left" Text="原始牌来源" VerticalAlignment="Center" Margin="0,0,8,0" />
                                        <ComboBox x:Name="AnalyzeNewLeafSourceComboBox" SelectedIndex="0" MinWidth="260" ToolTip="选择新叶要变化哪类已进入牌组的原始牌。">
                                            <ComboBoxItem Content="默认：本职业基础牌" Tag="starter_basic" />
                                            <ComboBoxItem Content="铅制镇纸给的无色卡" Tag="source:LeadPaperweight:any" />
                                            <ComboBoxItem Content="万花筒给的其它职业卡" Tag="source:Kaleidoscope:any" />
                                            <ComboBoxItem Content="失物盒选中的卡" Tag="source:LostCoffer:any" />
                                            <ComboBoxItem Content="沉重石板给的 Injury" Tag="source:HeftyTablet:Injury" />
