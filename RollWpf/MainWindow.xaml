                                    </DataGrid>
                                </DockPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>

                <Grid x:Name="EventsPage" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,14,0">
