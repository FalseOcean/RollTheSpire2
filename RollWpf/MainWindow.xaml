                                                    <TextBox x:Name="FinalRelicAllTextBox" AcceptsReturn="True" />
                                                    <TextBox x:Name="FinalRelicBlacklistTextBox" AcceptsReturn="True" />
                                                    <TextBox x:Name="FinalCardAnyTextBox" AcceptsReturn="True" />
                                                    <TextBox x:Name="FinalCardAllTextBox" AcceptsReturn="True" />
                                                    <TextBox x:Name="FinalCardBlacklistTextBox" AcceptsReturn="True" />
                                                    <TextBox x:Name="FinalCurseAnyTextBox" AcceptsReturn="True" />
                                                    <TextBox x:Name="FinalCurseBlacklistTextBox" AcceptsReturn="True" />
                                                    <TextBox x:Name="FinalPotionAnyTextBox" AcceptsReturn="True" />
                                                    <TextBox x:Name="FinalPotionAllTextBox" AcceptsReturn="True" />
                                                    <TextBox x:Name="FinalPotionBlacklistTextBox" AcceptsReturn="True" />
