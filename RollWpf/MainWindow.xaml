                                                <TextBlock Text="药水 blacklist" />
                                                <TextBox x:Name="PotionBlacklistTextBox" AcceptsReturn="True" MinHeight="54" />
                                            </StackPanel>
                                        </UniformGrid>
                                    </StackPanel>
                                </Border>
