                                            </StackPanel>
                                            <StackPanel>
                                                <TextBlock Text="不要出现的先古" />
                                                <TextBox x:Name="AncientBlacklistTextBox" AcceptsReturn="True" MinHeight="48" />
                                            </StackPanel>
                                        </UniformGrid>
                                        <UniformGrid Columns="2" Margin="0,6,0,8" Visibility="Collapsed">
                                            <StackPanel>
                                                <TextBlock Text="需要出现的定向选项" />
                                                <TextBox x:Name="AncientOptionRequireTextBox" AcceptsReturn="True" MinHeight="48" ToolTip="例如：Pael:Goopy 或 act3:Darv:Pandora" />
                                            </StackPanel>
                                            <StackPanel>
                                                <TextBlock Text="不想要的定向选项" />
                                                <TextBox x:Name="AncientOptionBlacklistTextBox" AcceptsReturn="True" MinHeight="48" />
