                                <TextBlock x:Name="HistoryStatusText" Text="收藏库未加载" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" Margin="12,0,0,0" />
                            </StackPanel>
                        </DockPanel>
                    </Border>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="520" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="收藏 / 搜索历史" FontWeight="SemiBold" Margin="4,0,4,8" />
                                <DataGrid x:Name="HistoryDataGrid" AutoGenerateColumns="False" IsReadOnly="True" SelectionChanged="HistoryDataGrid_SelectionChanged" CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="Horizontal">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="收藏" Binding="{Binding FavoriteLabel}" Width="52" />
                                        <DataGridTextColumn Header="Seed" Binding="{Binding Seed}" Width="118" />
                                        <DataGridTextColumn Header="角色" Binding="{Binding Character}" Width="118" />
                                        <DataGridTextColumn Header="A" Binding="{Binding AscensionText}" Width="42" />
                                        <DataGridTextColumn Header="标签" Binding="{Binding TagsText}" Width="120" />
                                        <DataGridTextColumn Header="摘要" Binding="{Binding Summary}" Width="*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource Card}">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                                    <TextBlock Text="选中记录" FontSize="18" FontWeight="SemiBold" />
                                    <TextBlock Text="收藏库 v2 保存爽种、筛种命中与单种分析记录；记录会携带 rng_version / RollTheSpire2 版本，避免旧 RNG 与 v0.107+ 结果混淆。粗筛候选库已启用，可从筛种结果保存候选池并继续精筛。" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,4,0,8" />
                                    <UniformGrid Columns="2">
                                        <StackPanel Margin="0,0,8,0">
                                            <TextBlock Text="Seed" />
                                            <TextBox x:Name="HistorySeedBox" IsReadOnly="True" FontFamily="Consolas, Microsoft YaHei UI" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="来源 / 时间" />
                                            <TextBox x:Name="HistoryMetaBox" IsReadOnly="True" />
                                        </StackPanel>
                                    </UniformGrid>
                                    <StackPanel Margin="0,8,0,0">
                                        <TextBlock Text="收藏" />
                                        <CheckBox x:Name="HistoryFavoriteCheckBox" Content="收藏为爽种" />
                                        <ComboBox x:Name="HistoryRatingComboBox" SelectedValuePath="Tag" Visibility="Collapsed">
                                            <ComboBoxItem Content="0" Tag="0" IsSelected="True" />
                                        </ComboBox>
                                    </StackPanel>
                                    <TextBlock Text="标签（逗号分隔，可编辑）" Margin="0,8,0,0" />
                                    <TextBox x:Name="HistoryTagsBox" />
                                    <TextBlock Text="备注（可编辑）" Margin="0,8,0,0" />
                                    <TextBox x:Name="HistoryNoteBox" AcceptsReturn="True" MinHeight="60" TextWrapping="Wrap" />
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                                        <Button Content="保存收藏/标签/备注" Click="SaveHistoryNote_Click" />
                                        <Button Content="删除记录" Click="DeleteHistoryRecord_Click" Background="#FF6B6B" Foreground="White" />
                                    </StackPanel>
                                </StackPanel>
                                <TextBox x:Name="HistoryDetailBox" FontFamily="Consolas, Microsoft YaHei UI" FontSize="13" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" IsReadOnly="True" />
                            </DockPanel>
                        </Border>
                    </Grid>
                </Grid>


                <Grid x:Name="CandidatePage" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Style="{StaticResource Card}" Padding="12" Margin="0,0,0,12">
                        <DockPanel LastChildFill="True">
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="刷新" Click="RefreshCandidatePools_Click" />
                                <Button Content="继续筛这个池" Click="UseCandidatePoolForSearch_Click" Background="{StaticResource PrimaryBrush}" Foreground="White" />
                                <Button Content="复制 Seeds" Click="CopyCandidatePoolSeeds_Click" />
                                <Button Content="导出 Seeds" Click="ExportCandidatePoolSeeds_Click" />
                                <Button Content="删除候选池" Click="DeleteCandidatePool_Click" Background="#FF6B6B" Foreground="White" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="搜索" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBox x:Name="CandidateQueryTextBox" Width="260" TextChanged="CandidateQueryTextBox_TextChanged" ToolTip="按候选池名称、角色、备注、标签或 seed 搜索。" />
                                <TextBlock x:Name="CandidateStatusText" Text="粗筛库未加载" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" Margin="12,0,0,0" />
                            </StackPanel>
                        </DockPanel>
                    </Border>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="520" />
                            <ColumnDefinition Width="*" />
