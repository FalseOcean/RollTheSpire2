                                                <TextBlock Text="商店专属遗物" />
                                                <ComboBox x:Name="ShopRelicBuilderComboBox" IsEditable="True" IsTextSearchEnabled="True" DisplayMemberPath="DisplayText" />
                                            </StackPanel>
