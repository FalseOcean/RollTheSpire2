                                            <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="50" />
                                            <DataGridTextColumn Header="Seed" Binding="{Binding Seed}" Width="140" />
                                            <DataGridTextColumn Header="摘要" Binding="{Binding Summary}" Width="*" />
