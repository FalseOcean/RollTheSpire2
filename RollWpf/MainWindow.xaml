                                                    <ComboBoxItem Content="Act3 / 第三层" Tag="act3" />
                                                </ComboBox>
                                            </StackPanel>
                                            <TextBlock Text="选择 Act2/Act3 会在右侧 Tag 中显示为 act2:Darv / act3:Darv。" TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}" Margin="10,18,0,0" />
                                        </UniformGrid>
                                        <TextBlock Text="当前游戏状态预设" FontWeight="SemiBold" Margin="4,4,4,4" />
                                        <UniformGrid Columns="2">
                                            <CheckBox x:Name="AncientPaelGoopyCheckBox" Content="Pael: Gooopy 可附魔防御牌 ≥ 3" IsChecked="True" />
                                            <CheckBox x:Name="AncientPaelRemovableCheckBox" Content="Pael: 可移除牌 ≥ 5" IsChecked="True" />
                                            <CheckBox x:Name="AncientPaelHasEventPetCheckBox" Content="Pael: 已有事件宠物" />
                                            <CheckBox x:Name="AncientOrobasTouchCheckBox" Content="Orobas: TouchOfOrobas 条件满足" IsChecked="True" />
                                            <CheckBox x:Name="AncientOrobasToothCheckBox" Content="Orobas: ArchaicTooth 条件满足" IsChecked="True" />
                                            <CheckBox x:Name="AncientTezcataraBasicStrikeCheckBox" Content="Tezcatara: 还有 Basic Strike" IsChecked="True" />
                                            <CheckBox x:Name="AncientNonupeipeSwiftCheckBox" Content="Nonupeipe: Swift 可附魔牌 ≥ 4" IsChecked="True" />
                                            <CheckBox x:Name="AncientTanxInstinctCheckBox" Content="Tanx: Instinct 可附魔牌 ≥ 3" IsChecked="True" />
                                            <CheckBox x:Name="AncientDarvPandoraCheckBox" Content="Darv: 允许潘多拉魔盒出现" IsChecked="True" />
                                        </UniformGrid>
                                    </StackPanel>
                                </Border>
                            </Expander>

                                </StackPanel>
                                <Border Grid.Column="1" Style="{StaticResource Card}" Margin="0">
                                    <DockPanel>
                                        <StackPanel DockPanel.Dock="Top">
                                            <TextBlock Text="当前 tag 要求" FontSize="18" FontWeight="SemiBold" />
                                            <TextBlock Text="这里汇总你在左侧添加的筛种要求。事件队列筛选匹配 Act1/2/3 的前 N 个默认可出现事件，N 最大 15，可在事件筛选区域选择作用 Act。" TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}" Margin="0,6,0,10" />
                                            <TextBlock x:Name="SearchTagCountText" Text="0 个 tag" Foreground="#1D4ED8" FontWeight="SemiBold" Margin="0,0,0,8" />
                                            <Button Content="刷新 tag 汇总" Click="RefreshSearchTags_Click" HorizontalAlignment="Left" />
                                        </StackPanel>
                                        <ListBox x:Name="SearchRequirementTagsListBox" BorderThickness="0" Margin="0,10,0,0">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1" CornerRadius="8" Padding="8" Margin="0,4">
                                                        <DockPanel>
                                                            <Button DockPanel.Dock="Right" Content="×" Width="24" Height="24" Padding="0" Margin="8,0,0,0"
                                                                    Click="DeleteSearchTag_Click"
                                                                    IsEnabled="{Binding CanRemove}"
                                                                    ToolTip="删除这个 Tag" />
                                                            <TextBlock Text="{Binding Text}" TextWrapping="Wrap" Foreground="#1E3A8A" VerticalAlignment="Center" />
                                                        </DockPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </DockPanel>
                                </Border>
                            </Grid>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
                                <Button x:Name="SearchButton" Content="开始筛种" Click="RunSearch_Click" Background="{StaticResource PrimaryBrush}" Foreground="White" />
                                <Button x:Name="StopSearchButton" Content="停止" Click="StopSearch_Click" IsEnabled="False" Background="#DC2626" Foreground="White" />
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="1" Style="{StaticResource Card}" Padding="12" Margin="0,12,0,0">
                        <DockPanel LastChildFill="True">
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="打开筛种结果" Click="NavSearchResults_Click" Background="{StaticResource PrimaryBrush}" Foreground="White" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="筛种进度" FontWeight="SemiBold" Margin="0,0,10,0" />
                                <TextBlock x:Name="SearchSummaryText" Text="就绪" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" TextWrapping="Wrap" />
                            </StackPanel>
                        </DockPanel>
                    </Border>
                </Grid>

                <Grid x:Name="SearchResultsPage" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Style="{StaticResource Card}" Padding="12" Margin="0,0,0,12">
                        <DockPanel LastChildFill="True">
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBox x:Name="CandidatePoolNameTextBox" Width="180" Text="粗筛候选池" ToolTip="保存当前筛种命中为候选池时使用的名称。" />
                                <Button Content="保存为粗筛库" Click="SaveCurrentHitsToCandidatePool_Click" />
                                <Button Content="打开粗筛库" Click="NavCandidate_Click" />
                                <Button Content="填到单种分析" Click="SendSelectedSeedToAnalyze_Click" />
                                <Button Content="收藏选中" Click="SaveSelectedSearchHitToHistory_Click" />
                                <Button Content="复制选中详情" Click="CopySearch_Click" />
                                <Button Content="复制全部命中" Click="CopyAllSearchHits_Click" />
                                <Button Content="复制选中 Seed" Click="CopySelectedSeed_Click" />
                                <Button Content="清空" Click="ClearSearch_Click" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="选中 Seed" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBox x:Name="SearchSelectedSeedBox" Width="220" IsReadOnly="True" FontFamily="Consolas, Microsoft YaHei UI" ToolTip="左侧选中命中结果后，这里会显示可复制的 seed" />
                            </StackPanel>
                        </DockPanel>
                    </Border>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="400" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="命中种子列表" FontWeight="SemiBold" Margin="4,0,4,8" />
                                <ListBox x:Name="SearchHitsListBox" SelectionChanged="SearchHitsListBox_SelectionChanged">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="8" Margin="0,3" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontFamily="Consolas, Microsoft YaHei UI" />
                                                    <TextBlock Text="{Binding CategoryText}" Foreground="#2563EB" FontSize="12" TextWrapping="Wrap" Margin="0,2,0,0" />
                                                    <TextBlock Text="{Binding Summary}" Foreground="#6B7280" FontSize="12" TextWrapping="Wrap" Margin="0,2,0,0" MaxHeight="58" />
                                                    <TextBlock Text="{Binding Meta}" Foreground="#9CA3AF" FontSize="11" Margin="0,2,0,0" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </DockPanel>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource Card}">
                            <DockPanel>
                                <Expander DockPanel.Dock="Top" Header="原始详情（点击展开 / 折叠）" IsExpanded="False" Margin="0,0,0,8">
                                    <Border Background="#F8FAFC" BorderBrush="#DDE6F3" BorderThickness="1" CornerRadius="8" Padding="8" Margin="0,6,0,0">
                                        <TextBox x:Name="SearchOutputBox" FontFamily="Consolas, Microsoft YaHei UI" FontSize="13" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" IsReadOnly="True" MinHeight="180" MaxHeight="320" />
                                    </Border>
                                </Expander>
                                <ListBox x:Name="SearchDetailCardsListBox" BorderThickness="0" Margin="0" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.CanContentScroll="False" HorizontalContentAlignment="Stretch">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="{x:Type ListBoxItem}">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            <Setter Property="Padding" Value="0" />
                                            <Setter Property="Margin" Value="0" />
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#F8FAFC" BorderBrush="#DDE6F3" BorderThickness="1" CornerRadius="10" Padding="12" Margin="4,5" HorizontalAlignment="Stretch">
                                                <StackPanel>
                                                    <DockPanel>
                                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="15" Foreground="#111827" />
                                                        <Border DockPanel.Dock="Right" Background="#ECFDF5" CornerRadius="8" Padding="8,2" Margin="8,0,0,0">
                                                            <TextBlock Text="{Binding Badge}" Foreground="#047857" FontSize="12" />
                                                        </Border>
                                                    </DockPanel>
                                                    <ItemsControl ItemsSource="{Binding Lines}" Margin="0,8,0,0">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding Text}" TextWrapping="Wrap" Foreground="{Binding ForegroundBrush}" FontWeight="{Binding FontWeight}" Margin="0,2" ToolTip="{Binding ToolTip}" />
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </DockPanel>
                        </Border>
                    </Grid>
                </Grid>

                <Grid x:Name="HistoryPage" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Style="{StaticResource Card}" Padding="12" Margin="0,0,0,12">
                        <DockPanel LastChildFill="True">
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="刷新" Click="RefreshHistory_Click" />
                                <Button Content="打开目录" Click="OpenHistoryFolder_Click" />
                                <Button Content="复制 Seed" Click="CopyHistorySeed_Click" />
                                <Button Content="复制详情" Click="CopyHistoryDetail_Click" />
                                <Button Content="复制可见 Seeds" Click="CopyVisibleHistorySeeds_Click" />
                                <Button Content="导出可见" Click="ExportVisibleHistory_Click" />
                                <Button Content="填到单种分析" Click="FillHistoryToAnalyze_Click" />
                                <Button Content="重新分析" Click="ReanalyzeHistory_Click" Background="{StaticResource PrimaryBrush}" Foreground="White" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="搜索" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
