                                                    <ComboBox Grid.Column="1" x:Name="FinalPotionBuilderComboBox" IsEditable="True" IsTextSearchEnabled="True" DisplayMemberPath="DisplayText" ToolTip="共享药水池 + 当前角色专属药水池。" />
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="8,0,0,0">
                                                        <Button Content="任一想要" Width="82" Click="AddFinalPotionAnyTag_Click" Background="{StaticResource PrimaryBrush}" Foreground="White" Margin="0,0,6,0" />
                                                        <Button Content="全部必须" Width="82" Click="AddFinalPotionAllTag_Click" Margin="0,0,6,0" />
                                                        <Button Content="不想要" Width="70" Click="AddFinalPotionBlacklistTag_Click" />
                                                    </StackPanel>
                                                </Grid>
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="110" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="最终诅咒" VerticalAlignment="Center" />
                                                    <ComboBox Grid.Column="1" x:Name="FinalCurseBuilderComboBox" IsEditable="True" IsTextSearchEnabled="True" DisplayMemberPath="DisplayText" ToolTip="骨骰诅咒池 + 固定 Greed / Injury。" />
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="8,0,0,0">
                                                        <Button Content="想要" Width="82" Click="AddFinalCurseAnyTag_Click" Background="{StaticResource PrimaryBrush}" Foreground="White" Margin="0,0,6,0" />
                                                        <Button Content="不想要" Width="82" Click="AddFinalCurseBlacklistTag_Click" />
                                                    </StackPanel>
                                                </Grid>
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="110" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="最终普通遗物" VerticalAlignment="Center" />
                                                    <ComboBox Grid.Column="1" x:Name="FinalRelicBuilderComboBox" IsEditable="True" IsTextSearchEnabled="True" DisplayMemberPath="DisplayText" ToolTip="只显示当前角色可用的普通 / 罕见 / 稀有随机遗物；不含 Neow / 商店 / 事件 / Ancient 遗物。" />
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="8,0,0,0">
                                                        <Button Content="任一想要" Width="82" Click="AddFinalRelicAnyTag_Click" Background="{StaticResource PrimaryBrush}" Foreground="White" Margin="0,0,6,0" />
                                                        <Button Content="全部必须" Width="82" Click="AddFinalRelicAllTag_Click" Margin="0,0,6,0" />
                                                        <Button Content="不想要" Width="70" Click="AddFinalRelicBlacklistTag_Click" />
                                                    </StackPanel>
                                                </Grid>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="110" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
