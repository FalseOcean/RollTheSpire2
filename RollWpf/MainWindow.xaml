                                    <TextBox x:Name="CandidatePoolMetaBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="96" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="1" Style="{StaticResource Card}">
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Top" Text="候选 Seeds（最多预览 5000 条）" FontWeight="SemiBold" Margin="4,0,4,8" />
                                    <DataGrid x:Name="CandidateSeedsDataGrid" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="Horizontal">
