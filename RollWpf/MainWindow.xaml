                                                <TextBox x:Name="BonesCurseAnyTextBox" />
                                                <TextBox x:Name="BonesCurseBlacklistTextBox" />
                                                <TextBox x:Name="PredictedRelicAnyTextBox" />
                                                <TextBox x:Name="PredictedRelicAllTextBox" />
                                                <TextBox x:Name="PredictedRelicBlacklistTextBox" />
                                                <TextBox x:Name="NewLeafCardAllTextBox" />
                                                <TextBox x:Name="KaleidoscopeGroup1CardAllTextBox" />
                                                <TextBox x:Name="KaleidoscopeGroup2CardAllTextBox" />
                                                <TextBox x:Name="LostCofferCardAllTextBox" />
                                                <TextBox x:Name="LostCofferPotionAllTextBox" />
