                            <StackPanel DockPanel.Dock="Top">
                                <TextBlock Text="事件检索" FontSize="18" FontWeight="SemiBold" />
                                <TextBox x:Name="EventSearchTextBox" TextChanged="EventSearchTextBox_TextChanged" ToolTip="搜索中文名、ID、条件文本、选项文本" />
                                <TextBlock Text="区域筛选" Foreground="{StaticResource MutedTextBrush}" Margin="4,4,0,2" />
                                <WrapPanel Margin="0,0,0,4">
                                    <CheckBox x:Name="FilterOvergrowthCheckBox" Content="密林" IsChecked="True" Checked="EventFilterChanged" Unchecked="EventFilterChanged" Margin="4,2" />
                                    <CheckBox x:Name="FilterUnderdocksCheckBox" Content="暗港" IsChecked="True" Checked="EventFilterChanged" Unchecked="EventFilterChanged" Margin="4,2" />
                                    <CheckBox x:Name="FilterHiveCheckBox" Content="巢穴" IsChecked="True" Checked="EventFilterChanged" Unchecked="EventFilterChanged" Margin="4,2" />
                                    <CheckBox x:Name="FilterGloryCheckBox" Content="荣耀" IsChecked="True" Checked="EventFilterChanged" Unchecked="EventFilterChanged" Margin="4,2" />
                                    <CheckBox x:Name="FilterSharedCheckBox" Content="共享" IsChecked="True" Checked="EventFilterChanged" Unchecked="EventFilterChanged" Margin="4,2" />
                                </WrapPanel>
                                <TextBlock Text="条件筛选" Foreground="{StaticResource MutedTextBrush}" Margin="4,4,0,2" />
                                <WrapPanel Margin="0,0,0,8">
                                    <CheckBox x:Name="FilterConditionalCheckBox" Content="有条件" IsChecked="True" Checked="EventFilterChanged" Unchecked="EventFilterChanged" Margin="4,2" />
                                    <CheckBox x:Name="FilterNoConditionCheckBox" Content="无条件" IsChecked="True" Checked="EventFilterChanged" Unchecked="EventFilterChanged" Margin="4,2" />
                                </WrapPanel>
                                <TextBlock x:Name="EventRuleSummaryText" Foreground="{StaticResource MutedTextBrush}" Margin="4,2,0,8" />
                            </StackPanel>
                            <ListBox x:Name="EventListBox" SelectionChanged="EventListBox_SelectionChanged" />
                        </DockPanel>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource Card}">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="刷新事件百科" Click="LoadEvents_Click" />
                                <Button Content="复制详情" Click="CopyEventDetail_Click" />
                            </StackPanel>
                            <TextBox x:Name="EventDetailBox" FontFamily="Consolas, Microsoft YaHei UI" FontSize="13" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" IsReadOnly="True" />
                        </DockPanel>
                    </Border>
                </Grid>

                <Grid x:Name="LogPage" Visibility="Collapsed">
                    <Border Style="{StaticResource Card}">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="复制日志" Click="CopyLog_Click" />
                                <Button Content="清空日志" Click="ClearLog_Click" />
                            </StackPanel>
                            <TextBox x:Name="LogBox" FontFamily="Consolas, Microsoft YaHei UI" FontSize="13" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" IsReadOnly="True" />
                        </DockPanel>
                    </Border>
                </Grid>

                <Grid x:Name="StatusPage" Visibility="Collapsed">
                    <Border Style="{StaticResource Card}">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                                <TextBlock Text="数据状态" FontSize="20" FontWeight="SemiBold" />
                                <TextBlock Text="汇总当前数据文件、解锁档案、事件规则、实体索引与运行配置。用于确认程序实际加载的内容。" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,4,0,8" />
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="刷新数据状态" Width="140" HorizontalAlignment="Left" Click="RefreshStatus_Click" />
                                    <Button Content="复制数据状态" Width="140" HorizontalAlignment="Left" Click="CopyStatus_Click" Margin="8,0,0,0" />
                                </StackPanel>
                            </StackPanel>
                            <TextBox x:Name="StatusBox" FontFamily="Consolas, Microsoft YaHei UI" FontSize="13" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" IsReadOnly="True" />
                        </DockPanel>
                    </Border>
                </Grid>
            </Grid>

            <Border Grid.Row="2" Background="#E5E7EB" CornerRadius="8" Padding="10" Margin="0,12,0,0">
                <DockPanel>
                    <TextBlock x:Name="BottomStatusText" Text="就绪" Foreground="#374151" />
                    <TextBlock DockPanel.Dock="Right" Text="RollTheSpire2 v2.1.0 · stable" Foreground="#6B7280" />
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
