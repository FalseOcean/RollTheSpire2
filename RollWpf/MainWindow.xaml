                                                        <Button Content="全部必须" Width="82" Click="AddFinalCardAllTag_Click" Margin="0,0,6,0" />
                                                        <Button Content="不想要" Width="70" Click="AddFinalCardBlacklistTag_Click" />
                                                    </StackPanel>
                                                </Grid>
                                                <Grid Margin="0,0,0,8">
