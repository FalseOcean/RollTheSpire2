                                                    <ComboBoxItem Content="3" Tag="3" />
                                                    <ComboBoxItem Content="4" Tag="4" />
                                                    <ComboBoxItem Content="5" Tag="5" IsSelected="True" />
                                                    <ComboBoxItem Content="6" Tag="6" />
                                                    <ComboBoxItem Content="7" Tag="7" />
                                                    <ComboBoxItem Content="8" Tag="8" />
