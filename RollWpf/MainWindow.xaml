                                                <TextBlock Text="前 N 个必须包含" />
                                                <TextBox x:Name="ShopRequireTextBox" AcceptsReturn="True" MinHeight="54" ToolTip="格式：Relic &lt;= N，由按钮生成。" />
                                            </StackPanel>
                                            <StackPanel>
                                                <TextBlock Text="禁止出现" />
                                                <TextBox x:Name="ShopBlacklistTextBox" AcceptsReturn="True" MinHeight="54" ToolTip="默认按检查前 N 个商店专属遗物判断。" />
