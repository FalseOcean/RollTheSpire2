                                                <CheckBox x:Name="ColorlessCardsEnabledCheckBox" Content="无色卡 colorless" Margin="4,0,4,4" />
                                                <TextBox x:Name="ColorlessCardsAnyTextBox" AcceptsReturn="True" MinHeight="54" ToolTip="colorless whitelist_any" />
