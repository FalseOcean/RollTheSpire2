                            <Expander Header="事件队列筛选（Act1/2/3 前 N 个默认可出现事件）" IsExpanded="False" Margin="0,0,0,12">
                                <Border Style="{StaticResource Card}" Margin="0">
                                    <StackPanel>
                                        <TextBlock Text="筛指定 Act 的前 N 个默认可出现事件是否包含目标事件；N 可在本区域设置，默认 10，最大 15。Act 只支持 1/2/3。通过下拉框选择作用 Act 和事件，再用按钮加入“必须包含”或“排除事件”Tag；不再保留手动事件输入框，也暂不显示“包含任一”选项。默认会排除当前 Act 必跳过、普通队列必跳过、起始偏移跳过的事件。" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,0,0,8" />
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="120" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="事件筛选前 N（≤15）" VerticalAlignment="Center" Margin="0,0,8,0" />
                                            <TextBox Grid.Column="1" x:Name="SearchEventLimitTextBox" Text="10" ToolTip="批量筛种事件队列筛选范围。默认 10，上限 15；只影响事件筛选，不影响单种分析显示数量。" />
                                            <TextBlock Grid.Column="2" Text="作用 Act" VerticalAlignment="Center" Margin="16,0,8,0" />
                                            <ComboBox Grid.Column="3" x:Name="EventActScopeComboBox" SelectedIndex="0" ToolTip="选择事件筛选作用的 Act。任意 Act 表示不限定 Act；选择 Act1/Act2/Act3 时，后续添加的事件 Tag 会自动限定到对应 Act。">
                                                <ComboBoxItem Content="任意 Act" Tag="any" IsSelected="True" />
                                                <ComboBoxItem Content="Act1" Tag="1" />
                                                <ComboBoxItem Content="Act2" Tag="2" />
                                                <ComboBoxItem Content="Act3" Tag="3" />
                                            </ComboBox>
                                            <TextBlock Grid.Column="4" Text="只匹配默认可出现事件队列；完整原始队列仅用于单种分析查看。" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" VerticalAlignment="Center" Margin="12,0,0,0" />
                                        </Grid>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                                <TextBlock Text="事件选择" />
                                                <ComboBox x:Name="EventBuilderComboBox" IsEditable="True" IsTextSearchEnabled="True" DisplayMemberPath="DisplayText" ToolTip="可输入关键字搜索，但最终应选择下拉候选事件；选择后用右侧按钮加入事件队列筛选。" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                                                <Button Content="加入必须包含" MinWidth="112" Click="AddEventAllTag_Click" Background="{StaticResource PrimaryBrush}" Foreground="White" Margin="0,0,6,0" />
                                                <Button Content="加入排除事件" MinWidth="112" Click="AddEventBlacklistTag_Click" Margin="0,0,6,0" />
                                                <Button Content="清空事件 Tag" MinWidth="112" Click="ClearEventTags_Click" />
                                            </StackPanel>
                                        </Grid>
                                        <TextBlock Text="已添加事件会显示在下方条件表中；每条条件保存添加时的 Act 与前 N 设置，可单独删除。当前只暴露“必须包含”和“排除事件”。" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,2,0,8" />
                                        <Border Background="#F8FAFC" BorderBrush="#DDE6F3" BorderThickness="1" CornerRadius="8" Padding="8" Margin="0,0,0,8">
                                            <StackPanel>
                                                <DockPanel Margin="0,0,0,6">
                                                    <TextBlock Text="事件筛选条件表" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                    <TextBlock DockPanel.Dock="Right" Text="Act / 前N / 条件 / 事件" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" />
                                                </DockPanel>
                                                <ListBox x:Name="EventFilterConditionsListBox" BorderThickness="0" Background="Transparent" MaxHeight="180">
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6" Padding="6" Margin="0,3">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="68" />
                                                                        <ColumnDefinition Width="64" />
                                                                        <ColumnDefinition Width="92" />
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Grid.Column="0" Text="{Binding ActText}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                                    <TextBlock Grid.Column="1" Text="{Binding LimitText}" VerticalAlignment="Center" />
                                                                    <TextBlock Grid.Column="2" Text="{Binding ConditionText}" VerticalAlignment="Center" />
                                                                    <TextBlock Grid.Column="3" Text="{Binding EventText}" TextWrapping="Wrap" VerticalAlignment="Center" />
                                                                    <Button Grid.Column="4" Content="删除" Click="RemoveEventCondition_Click" Padding="8,2" Margin="8,0,0,0" />
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>
                                                <TextBlock x:Name="EventFilterConditionsEmptyText" Text="暂无事件筛选条件。" Foreground="{StaticResource MutedTextBrush}" Margin="2,4,0,0" />
                                            </StackPanel>
                                        </Border>
                                        <Grid Visibility="Collapsed">
                                            <TextBox x:Name="EventAnyTextBox" AcceptsReturn="True" />
                                            <TextBox x:Name="EventAllTextBox" AcceptsReturn="True" />
                                            <TextBox x:Name="EventBlacklistTextBox" AcceptsReturn="True" />
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </Expander>

